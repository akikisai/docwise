{
  "name": "docwise",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d postgres minio && pnpm --filter @docwise/bff dev & pnpm --filter @docwise/web dev",
    "dev:bff": "pnpm --filter @docwise/bff dev",
    "dev:web": "pnpm --filter @docwise/web dev",
    "lint": "eslint . --ext .ts,.tsx",
    "db:reset": "tsx --env-file=.env.local scripts/reset-db.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@mastra/core": "^1.22.0",
    "@mastra/pg": "^1.8.0",
    "@mastra/rag": "^2.1.0",
    "@repo/shared": "workspace:*",
    "ai": "^6.0.0",
    "neverthrow": "^8.2.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ]
  }
}
